# ──────────────────────────────────────────────────────────
#  DSA — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────────────────────

# URL pública do frontend na Hostinger (sem barra final)
# Separe múltiplos domínios por vírgula se necessário
FRONTEND_URL=https://seudominio.com.br

# Segredo JWT — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=coloque-aqui-um-segredo-forte-de-64-chars

# URL pública deste backend no Render (usada em links de e-mail)
BASE_URL=https://dsa-api.onrender.com

# ── Disco Persistente no Render (plano pago) ──────────────
# Crie o disco no painel Render → Service → Disks → Mount Path: /var/data
# Sem isso os dados são perdidos a cada redeploy (filesystem efêmero)
DATA_DIR=/var/data

# ── SMTP para recuperação de senha (opcional) ─────────────
# Sem estas variáveis o link de reset aparece no console do servidor
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu@gmail.com
SMTP_PASS=senha-de-app-google
