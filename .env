# ─── SERVIDOR ────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000

# Chave secreta para JWT (troque por uma string aleatória longa em produção)
JWT_SECRET=dsa-mude-esta-chave-secreta-em-producao

# ─── E-MAIL SMTP (opcional) ───────────────────────────────
# Se não configurado, o link de recuperação aparece no console do servidor.
#
# Para Gmail: use uma "Senha de App" (não a senha normal).
# Ative em: Conta Google → Segurança → Verificação em 2 etapas → Senhas de app
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha-de-app-16-digitos
# SMTP_FROM="DSA — Servidores do Altar" <seu-email@gmail.com>
